func spaces(int n) -> string {
    string s = "";
    int i = 0;
    while (i < n) { s = s + " "; i = i + 1; }
    return s;
}
func row(int n) -> string { return spaces(4 - digits(n)) + numstr(n); }
func digits(int n) -> int { int d = 1; while (n >= 10) { n = n / 10; d = d + 1; } return d; }
func numstr(int n) -> string { return "" + n; }      // int -> string via concat
func main() -> void {
    int i = 1;
    while (i <= 4) { println(row(i * i * i)); i = i + 1; }
}
